# Salin berkas ini menjadi ".env" lalu sesuaikan nilainya dengan aplikasi Anda.
#   cp .env.example .env     (Linux/Mac)
#   copy .env.example .env   (Windows)

# ============================================================
# Identitas aplikasi yang dianalisis
# ============================================================
# Nama tampilan, dipakai pada judul grafik & laporan.
APP_NAME=Sentuh Tanahku

# ============================================================
# Sumber data — kosongkan platform yang tidak dipakai
# ============================================================

# --- Google Play Store ---
# Ambil dari URL aplikasi: play.google.com/store/apps/details?id=<APP_ID>
PLAYSTORE_APP_ID=id.go.bpn.sentuh
PLAYSTORE_LANG=id
PLAYSTORE_COUNTRY=id

# --- Apple App Store ---
# Ambil dari URL aplikasi: apps.apple.com/.../id<APP_ID>
APPSTORE_APP_ID=1287142144
APPSTORE_COUNTRY=id

# --- TikTok ---
# ms_token diambil dari cookie browser saat login TikTok:
#   DevTools > Application > Cookies > https://www.tiktok.com > msToken
TIKTOK_MS_TOKEN=
# Daftar id video (pisahkan dengan koma). Ambil dari URL: tiktok.com/@user/video/<ID>
TIKTOK_VIDEO_IDS=7592079631126154514,7318617161054866694,7277439276973853957

# ============================================================
# Opsional — biarkan default jika tidak yakin
# ============================================================
# MODEL_NAME=cardiffnlp/twitter-xlm-roberta-base-sentiment
# RESOURCES_DIR=resources
# DATA_DIR=data
# OUTPUT_DIR=output
